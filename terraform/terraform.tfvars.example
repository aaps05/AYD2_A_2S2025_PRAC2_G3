# Copy this file to terraform.tfvars and fill in your values
# terraform.tfvars is git-ignored — never commit real credentials

aws_region    = "us-east-1"
key_pair_name = "my-aws-keypair"        # Name of your existing EC2 Key Pair in AWS
db_password   = "ChangeMe_Strong_Pass1" # Min 8 chars, mix of letters/numbers
admin_cidr    = "0.0.0.0/0"            # Restrict to your IP: "x.x.x.x/32"
instance_type = "t3.micro"
